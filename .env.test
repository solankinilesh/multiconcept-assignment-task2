# Test env: file-based SQLite (so schema persists across the suite); DAMA wraps each
# test in a transaction that rolls back. Sync messenger transport so tests don't need a worker.
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_test.db"
MESSENGER_TRANSPORT_DSN=in-memory://
MESSENGER_FAILED_DSN=in-memory://
WEBHOOK_STRIPE_SECRET=whsec_test_only_stripe
WEBHOOK_MAILGUN_SECRET=whsec_test_only_mailgun
WEBHOOK_REPLAY_TOLERANCE=300
