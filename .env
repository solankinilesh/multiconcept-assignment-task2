# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=ChangeMeForProductionUseAStringOf32CharsOrMore
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Default: SQLite at var/data_<env>.db so we can run with zero infrastructure.
# To switch to MySQL/Postgres in production, set DATABASE_URL in .env.local — no code changes.
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# Doctrine transport reuses DATABASE_URL, so no extra infrastructure is needed.
# In production: switch to redis:// or amqp:// for higher throughput.
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=webhooks
MESSENGER_FAILED_DSN=doctrine://default?queue_name=failed
###< symfony/messenger ###

###> app/webhooks ###
# Provider signing secrets. Replace with real values from each provider's dashboard.
# Loaded by the matching SignatureVerifier; never logged.
WEBHOOK_STRIPE_SECRET=whsec_test_stripe_secret_replace_me
WEBHOOK_MAILGUN_SECRET=whsec_test_mailgun_secret_replace_me
# Tolerance window in seconds for replay protection (Stripe).
WEBHOOK_REPLAY_TOLERANCE=300
###< app/webhooks ###
